# EAS build uploads the project as a tarball using these rules instead of
# .gitignore. src/config.local.ts is intentionally excluded from git (it
# holds the real jsonbin write key) but EAS still needs the actual file on
# disk to bundle it into the build, so it must NOT be excluded here.

node_modules/
.expo/
dist/
web-build/
expo-env.d.ts

.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision
/ios
/android

.metro-health-check*

.env
.env*.local

npm-debug.*
yarn-debug.*
yarn-error.*

.DS_Store
*.pem
Thumbs.db

*.tsbuildinfo
